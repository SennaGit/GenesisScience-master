{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genesis Science",
  "version": "0.1.0",
  "identifier": "com.aethersynth.genesisscience",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @aether-synth/desktop exec vite --port 5173 --strictPort",
    "beforeBuildCommand": "pnpm --filter @aether-synth/desktop build"
  },
  "app": {
    "windows": [
      {
        "title": "Genesis Science",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/opencode", "binaries/uv"],
    "resources": {
      "../../../runtime/skills/external/aether-synth-skills": "skills/",
      "../../../runtime/skills/core": "skills-core/",
      "../../../examples/climate-trends": "examples/climate-trends/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
